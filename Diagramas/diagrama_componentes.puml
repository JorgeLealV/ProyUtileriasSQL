@startuml
' !theme materia
title Diagrama de Componentes - Utilerías SQL

!define ICONURL https://raw.githubusercontent.com/tupadr3/plantuml-icon-font-sprites/v2.4.0
!includeurl ICONURL/common.puml
!includeurl ICONURL/devicons/python.puml
!includeurl ICONURL/devicons/postgresql.puml
!includeurl ICONURL/font-awesome-5/file_excel.puml
!includeurl ICONURL/font-awesome-5/file_code.puml
!includeurl ICONURL/font-awesome-5/window_maximize.puml
!includeurl ICONURL/font-awesome-5/cogs.puml
!includeurl ICONURL/font-awesome-5/database.puml

skinparam componentStyle uml2
skinparam Linetype ortho

actor "Usuario" as User

package "Aplicación de Escritorio" {
    [main.py <$python>] as Main

    component "Interfaz de Usuario (PySide6)" as GUI {
        [views/panel_principal_view.py <$python>] as View
        [ui/PanelPrincipal.ui <$file_code>] as UI_File
        [ui/main_window.ui <$file_code>] as UI_Main_File
    }

    component "Lógica de Negocio" as Services {
        [services/funciones.py <$cogs>] as Funciones
    }
}

package "Recursos de Datos" {
    database "Configuración" as Config {
        [ConfInsert.txt] as ConfigFile
    }

    artifact "Entrada de Datos" as InputData {
        [Datos.xlsx <$file_excel>] as ExcelFile
    }

    artifact "Salida Generada" as OutputData {
        [output.sql <$file_code>] as SQLFile
    }

    database "Base de Datos" as DB {
        [PostgreSQL <$postgresql>] as PostgreSQL
    }
}


User -- Main : Ejecuta

Main -- GUI : Inicia

GUI -- Services : Llama a funciones

Services -- Config : Lee configuración
Services -- InputData : Procesa archivo
Services -- OutputData : Genera script
Services -- DB : Ejecuta queries

@enduml
